# Copy to .env (git-ignored, chmod 600) for docker compose. Holds the AirTrail
# API key — a SECRET — so never commit the real .env.

# --- AirTrail dedup (GET /api/flight/list) ---
AIRTRAIL_URL=http://airtrail-host:3006
AIRTRAIL_API_KEY=REPLACE_ME

# --- scheduling (local time; DST-aware via TZ) ---
TZ=Europe/Berlin
SCHEDULE_MODE=weekly        # weekly | interval
# weekly mode:
SCHEDULE_DOW=0              # 0=Mon, 1=Tue, ... 6=Sun
SCHEDULE_HOUR=7
SCHEDULE_MINUTE=0
# interval mode (continuous scan): set SCHEDULE_MODE=interval and pick the gap
SCAN_INTERVAL_MINUTES=30
RUN_ON_START=true          # also run once when the container starts

# --- notifications (optional; fire only when NEW flights are found) ---
# WEBHOOK_URL=https://hooks.example.com/...   # POST a JSON digest
# NOTIFY_CMD=telegram-send --stdin            # pipe the text summary to a command

# --- automatic write (optional, opt-in) ---
# Writes only high-confidence, non-rebooking NEW flights straight to AirTrail;
# anything uncertain or flagged still waits for `populate.py --commit`.
# AUTO_WRITE=false

# --- local-LLM fallback (Phase 2, optional, opt-in) ---
# Parses the long tail (Ryanair/Wizz/LATAM/OTAs) the deterministic templates miss,
# via an OpenAI-compatible endpoint (e.g. Open WebUI). LLM candidates are ALWAYS
# uncertain — they surface for review and never auto-write. Off unless LLM_FALLBACK
# is truthy AND LLM_URL + LLM_MODEL are set.
# LLM_FALLBACK=false
# LLM_URL=http://airtrail-host:3000
# LLM_MODEL=llama3.1:8b
# LLM_API_KEY=REPLACE_ME
